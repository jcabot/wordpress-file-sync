# Port the Express server listens on (loopback only).
WPSYNC_PORT=4319

# Set to "1" to enable dev mode: server skips static-serving so the Vite dev
# server (port 5173) is the user-facing entry point.
WPSYNC_DEV=0

# Whether to auto-open the default browser when the server starts (only in
# production mode; in dev the launcher opens the browser separately).
WPSYNC_OPEN_BROWSER=true
