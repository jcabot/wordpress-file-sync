{
  "name": "@wpsync/gui",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "description": "Local Express + React web GUI for wpsync.",
  "main": "./dist-server/main.js",
  "files": [
    "dist-server",
    "dist-client",
    "server",
    "client",
    "start.bat",
    "start.sh"
  ],
  "scripts": {
    "build": "tsc -b server/tsconfig.json && vite build --config client/vite.config.ts",
    "build:server": "tsc -b server/tsconfig.json",
    "build:client": "vite build --config client/vite.config.ts",
    "clean": "tsc -b server/tsconfig.json --clean",
    "test": "vitest run --passWithNoTests",
    "dev": "run-p dev:server dev:client",
    "dev:server": "tsx watch server/src/main.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "start": "node dist-server/main.js",
    "typecheck": "tsc -b server/tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@wpsync/core": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.475.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "npm-run-all2": "^7.0.2",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.21.0",
    "vite": "^6.0.7"
  }
}
