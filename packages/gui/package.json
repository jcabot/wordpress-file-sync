{
  "name": "@wpsync/gui",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "description": "Electron + React GUI for wpsync.",
  "main": "./dist-electron/main.js",
  "files": [
    "dist-electron",
    "dist-renderer",
    "electron",
    "src",
    "index.html"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "build:electron": "tsc -b",
    "build:renderer": "vite build",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "clean": "tsc -b --clean",
    "test": "vitest run --passWithNoTests",
    "dev": "concurrently -k -n vite,electron \"vite\" \"tsx --watch electron/main.ts\"",
    "dev:renderer": "vite",
    "dev:electron": "tsx --watch electron/main.ts",
    "start": "electron .",
    "dist": "pnpm build && electron-builder",
    "dist:win": "node scripts/dist-win.mjs",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:linux": "pnpm build && electron-builder --linux"
  },
  "dependencies": {
    "@wpsync/core": "workspace:*",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "tsx": "^4.21.0",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.livablesoftware.wpsync",
    "productName": "wpsync",
    "copyright": "Jordi Cabot",
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist-electron/main.js"
    },
    "asar": true,
    "asarUnpack": [
      "**/keytar/**",
      "**/@iarna/toml/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
