# Dependencies
node_modules/
.tools/

# TypeScript / Vite build output
dist/
**/dist-server/
**/dist-client/
*.tsbuildinfo
coverage/

# Atomic-write temp files left behind by an interrupted pull or push
**/*.tmp.[0-9]*

# Local-only sync state inside any content directory (stored Application
# Password — never commit credentials)
**/.wpsync/credentials.json

# Integration fixture state (provisioned by wp-init.mjs; contains the
# WordPress Application Password for the local Docker fixture)
test/fixtures/wordpress/app-password.txt

# Debug PHP probes occasionally dropped into the fixture during diagnosis
test/fixtures/wordpress/_*.php

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Local env (GUI server port + open-browser flag)
packages/gui/.env

# Logs
*.log
